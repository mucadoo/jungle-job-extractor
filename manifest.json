{
  "manifest_version": 2,
  "name": "Text Extractor",
  "version": "1.0",
  "description": "Extracts text based on class and copies it to the clipboard.",
  "permissions": ["activeTab"],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}
