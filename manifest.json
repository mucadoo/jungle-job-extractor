{
  "manifest_version": 2,
  "name": "WTJ Job Details Extractor",
  "version": "1.0",
  "description": "Extract and copy job listing details to your clipboard from 'Welcome To The Jungle' job pages.",
  "permissions": ["activeTab", "tabs", "http://*/*", "https://*/*"],
  "browser_action": {
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "css": ["style.css"]
    }
  ]
}
